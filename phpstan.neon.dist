includes:
    - phpstan-baseline.neon

parameters:
    level: 5
    paths:
        - src
        - config
        - database
    tmpDir: build/phpstan
    configDirectories:
        - config
    ignoreErrors:
        -
            message: '#Class App\\Models\\User not found#'
            path: config/gezel.php
        -
            identifier: trait.unused
            path: src/Concerns/HasGezelAgent.php
        -
            # Under Testbench the container binds ExceptionHandler to
            # Collision's handler, which happens to have renderable(), so
            # PHPStan reads this guard as always true. It is not: an app is
            # free to bind a handler implementing only the contract, which
            # declares no renderable(), and that is the case this guards.
            identifier: function.alreadyNarrowedType
            path: src/GezelServiceProvider.php
